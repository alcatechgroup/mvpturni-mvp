APP_NAME="Turni Admin"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8002

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

# Hash de senha — Argon2id (ADR-007). Precisa casar com a API, que escreve os hashes
# no banco compartilhado; sem isso o Backoffice não valida senhas semeadas pela API.
HASH_DRIVER=argon2id
BCRYPT_ROUNDS=12

# Log JSON em stdout (ADR-008) — paridade dev↔prod, sem código.
LOG_CHANNEL=stderr
LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL — MESMO banco do api (um único Postgres, ADR-002).
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=turni
DB_USERNAME=turni
DB_PASSWORD=turni

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="nao-responder@turni.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# Pagar.me (ADR-005): mock local. O admin não chama o PSP direto — fica no worker
# (ADR-002/005); a var existe para paridade de config entre os apps.
PAGARME_DRIVER=mock
PAGARME_BASE_URL=http://pagarme-mock:8080
