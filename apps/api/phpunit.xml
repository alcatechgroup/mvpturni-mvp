<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
            <directory>database/seeders</directory>
        </include>
        <exclude>
            <!-- Fortify stubs publicados — implementação fica para STORY-017/018/021 -->
            <directory>app/Actions</directory>
            <!-- FortifyServiceProvider publica routes de Fortify — não testado isoladamente -->
            <file>app/Providers/FortifyServiceProvider.php</file>
        </exclude>
    </source>
    <coverage>
        <report>
            <text outputFile="php://stderr"/>
        </report>
    </coverage>
    <php>
        <!-- <server> escreve em $_SERVER, que o env() do Laravel lê ANTES de $_ENV/getenv.
             O docker-compose injeta APP_ENV=local em $_SERVER (variables_order inclui E),
             então só <server force> garante que a suíte rode como `testing` (sem isso,
             runningUnitTests()=false e o CSRF não é dispensado nos testes de rota web). -->
        <server name="APP_ENV" value="testing" force="true"/>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <!-- Testes de integração rodam contra PostgreSQL real (CA-6 / quality-standards 2.4),
             em banco isolado (turni_test) para não tocar os dados de dev.
             force="true" é OBRIGATÓRIO: o docker-compose injeta DB_DATABASE=turni como
             env var do container; sem force, o <env> não sobrescreve e o RefreshDatabase
             apagaria o banco de dev (turni). -->
        <env name="DB_CONNECTION" value="pgsql" force="true"/>
        <env name="DB_HOST" value="postgres" force="true"/>
        <env name="DB_PORT" value="5432" force="true"/>
        <env name="DB_DATABASE" value="turni_test" force="true"/>
        <env name="DB_USERNAME" value="turni" force="true"/>
        <env name="DB_PASSWORD" value="turni" force="true"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="SANCTUM_STATEFUL_DOMAINS" value="localhost,127.0.0.1"/>
        <env name="HASH_DRIVER" value="argon2id"/>
        <env name="BACKOFFICE_URL" value="http://localhost:8002"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
