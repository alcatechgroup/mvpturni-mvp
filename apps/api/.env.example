APP_NAME="Turni API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Log JSON em stdout (ADR-008) — paridade dev↔prod. O canal `stderr` do Laravel
# já aceita um formatter por env; usamos o JsonFormatter do Monolog sem código.
LOG_CHANNEL=stderr
LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL (ADR-000) — host `postgres` é o serviço do docker-compose.
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=turni
DB_USERNAME=turni
DB_PASSWORD=turni

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.turni.com.br

# Auth: Argon2id conforme ADR-007 §a
HASH_DRIVER=argon2id

# Sanctum SPA (ADR-007 §b): domínios que podem usar sessão stateful
SANCTUM_STATEFUL_DOMAINS=app.turni.com.br,app.homolog.turni.com.br,localhost:8003,127.0.0.1:8003

# Admin URL — exposta para o frontend WebApp no erro de admin_must_use_backoffice
BACKOFFICE_URL=http://localhost:8002

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Fila sobre o Postgres (driver database) — sem Redis no MVP (ADR-001/002).
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="nao-responder@turni.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# Pagar.me (ADR-005): mock em container é o default local; nunca chama o real em dev.
PAGARME_DRIVER=mock
PAGARME_BASE_URL=http://pagarme-mock:8080
