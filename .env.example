# .env da RAIZ — consumido pelo docker-compose (substituição de ${VAR}).
# Copie para `.env` (o `make setup` faz isso quando ausente). NUNCA comite `.env`.
# Segredos reais de homolog/prod vivem no Secret Manager (ADR-004), não aqui.

# --- PostgreSQL (container local; gerenciado/Cloud SQL em prod) ---
POSTGRES_DB=turni
POSTGRES_USER=turni
POSTGRES_PASSWORD=turni
# Porta publicada no host (a interna do container é sempre 5432). 5433 evita o
# conflito comum com um PostgreSQL/Docker já ocupando a 5432 na máquina.
POSTGRES_PORT=5433

# --- Portas publicadas no host ---
API_PORT=8001
ADMIN_PORT=8002
WEBAPP_PORT=8003
PAGARME_MOCK_PORT=8090

# --- Pagar.me (ADR-005): mock local é o default; sandbox/live só em CI/ambientes ---
PAGARME_DRIVER=mock
