.DS_Store

# Segredos / ambiente — .env NUNCA é versionado; .env.example SIM (ADR-004)
.env
.env.*
!.env.example
apps/*/.env

# PHP / Laravel
/apps/*/vendor/
/packages/*/vendor/
/apps/*/storage/*.key
/apps/*/storage/logs/*
/apps/*/storage/framework/cache/data/*
/apps/*/storage/framework/sessions/*
/apps/*/storage/framework/views/*
/apps/*/bootstrap/cache/*.php
.phpunit.result.cache
.phpunit.cache/

# Flutter / Dart (WebApp)
/apps/webapp/.dart_tool/
/apps/webapp/build/
/apps/webapp/.flutter-plugins
/apps/webapp/.flutter-plugins-dependencies

# Node (tooling eventual)
node_modules/

# Cobertura
coverage/
clover.xml
coverage.xml

# Terraform — state e vars com segredos nunca versionados
infra/**/.terraform/
infra/**/.terraform.lock.hcl
infra/**/terraform.tfvars
infra/**/terraform.tfstate
infra/**/terraform.tfstate.backup
*.tfplan

# Firebase — token de auth local (não é o service account do CI)
.firebase/

