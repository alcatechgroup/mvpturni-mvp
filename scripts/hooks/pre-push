#!/usr/bin/env bash
# Hook de pré-push do Turni (quality-standards.md §2.2 / IDR-004).
# Falha aqui = `git push` abortado. Instalado por `make hooks` (core.hooksPath).
#
# Roda, nesta ordem (barato → caro):
#   1) detector de segredos mínimo (segredos nunca commitados — secção 4)
#   2) lint (dart format check + Laravel Pint)
#   3) suíte de testes: unit + integração contra Postgres + cobertura (`make test`)
#
# E2E em browser real (Playwright) NÃO roda aqui — é gate LOCAL MANUAL antes de
# criar tag rc.N: `make e2e` (sobe docker-compose + roda Playwright contra
# localhost:8002/8003). Pipeline de release faz apenas smoke curl (IDR-004).
set -uo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

red()  { printf '\033[31m%s\033[0m\n' "$*"; }
grn()  { printf '\033[32m%s\033[0m\n' "$*"; }

echo "── pré-push: detector de segredos ──"

# Bloqueia arquivos .env (que não sejam .env.example) versionados.
if git ls-files | grep -E '(^|/)\.env($|\.)' | grep -v '\.env\.example$' >/dev/null 2>&1; then
  red "ABORTADO: arquivo .env versionado detectado. Segredos não vão para o git (ADR-004 / quality-standards 4)."
  git ls-files | grep -E '(^|/)\.env($|\.)' | grep -v '\.env\.example$'
  exit 1
fi

# Procura padrões óbvios de segredo nos arquivos rastreados (heurística mínima).
SECRET_PATTERN='(-----BEGIN [A-Z ]*PRIVATE KEY-----|AKIA[0-9A-Z]{16}|AWS_SECRET_ACCESS_KEY=.+|PAGARME_(SECRET|API)_KEY=sk_[a-zA-Z0-9]+)'
if git grep -nIE "$SECRET_PATTERN" -- ':!*.env.example' ':!scripts/hooks/pre-push' >/dev/null 2>&1; then
  red "ABORTADO: possível segredo encontrado no código rastreado:"
  git grep -nIE "$SECRET_PATTERN" -- ':!*.env.example' ':!scripts/hooks/pre-push'
  exit 1
fi
grn "ok: nenhum segredo detectado"

echo "── pré-push: lint (dart format + pint) ──"
if command -v dart >/dev/null 2>&1; then
  (cd apps/webapp && dart format --output none --set-exit-if-changed lib/) \
    || { red "ABORTADO: dart format reclamou em apps/webapp/lib/"; exit 1; }
else
  echo "AVISO: dart não está no PATH — pulando dart format check (CI vai pegar)."
fi
if command -v php >/dev/null 2>&1; then
  for app in api admin; do
    if [ -x "apps/$app/vendor/bin/pint" ]; then
      (cd "apps/$app" && ./vendor/bin/pint --test) \
        || { red "ABORTADO: pint reclamou em apps/$app"; exit 1; }
    else
      echo "AVISO: apps/$app/vendor/bin/pint ausente — pulando (rode composer install)."
    fi
  done
else
  echo "AVISO: php não está no PATH — pulando pint check (CI vai pegar)."
fi
grn "ok: lint sem regressões"

echo "── pré-push: suíte de testes (unit + integração + cobertura) ──"
if ! make test; then
  red "ABORTADO: a suíte de testes falhou. Push cancelado."
  exit 1
fi

grn "pré-push ok — push liberado"
exit 0
