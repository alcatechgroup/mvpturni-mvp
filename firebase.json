{
  "hosting": [
    {
      "target": "homolog",
      "public": "apps/webapp/build/web",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        {
          "source": "/index.html",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
          ]
        },
        {
          "source": "/version.json",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
          ]
        },
        {
          "source": "/health.json",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
            { "key": "Content-Type", "value": "application/json; charset=utf-8" }
          ]
        },
        {
          "source": "**/*.@(js|css|wasm)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
          ]
        }
      ],
      "rewrites": [
        { "source": "/health", "destination": "/health.json" },
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "prod",
      "public": "apps/webapp/build/web",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        {
          "source": "/index.html",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
          ]
        },
        {
          "source": "/version.json",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
          ]
        },
        {
          "source": "/health.json",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
            { "key": "Content-Type", "value": "application/json; charset=utf-8" }
          ]
        },
        {
          "source": "**/*.@(js|css|wasm)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
          ]
        }
      ],
      "rewrites": [
        { "source": "/health", "destination": "/health.json" },
        { "source": "**", "destination": "/index.html" }
      ]
    }
  ]
}
